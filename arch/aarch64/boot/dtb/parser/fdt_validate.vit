space arch/aarch64/boot/dtb/parser/fdt_validate

form ParserState {
    offset: u64
    size: u64
    valid: bool
}

proc initialize() -> ParserState {
    give ParserState {
        offset: 0,
        size: 0,
        valid: true
    }
}

proc parse() {
    emit "fdt_validate parse"
}

proc validate() -> bool {
    give true
}

proc debug() {
    emit "fdt_validate debug"
}
