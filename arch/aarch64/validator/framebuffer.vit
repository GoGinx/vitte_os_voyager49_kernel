space arch/aarch64/boot/dtb/validator/framebuffer

form ValidationResult {
    valid: bool
    reason: string
}

proc validate() -> ValidationResult {
    give ValidationResult {
        valid: true,
        reason: "framebuffer ok"
    }
}

proc repair() {
    emit "framebuffer repair"
}

proc diagnostics() {
    emit "framebuffer diagnostics"
}
