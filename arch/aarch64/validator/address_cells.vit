space arch/aarch64/boot/dtb/validator/address_cells

form ValidationResult {
    valid: bool
    reason: string
}

proc validate() -> ValidationResult {
    give ValidationResult {
        valid: true,
        reason: "address_cells ok"
    }
}

proc repair() {
    emit "address_cells repair"
}

proc diagnostics() {
    emit "address_cells diagnostics"
}
