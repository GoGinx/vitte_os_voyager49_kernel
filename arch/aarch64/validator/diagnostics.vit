space arch/aarch64/boot/dtb/validator/diagnostics

form ValidationResult {
    valid: bool
    reason: string
}

proc validate() -> ValidationResult {
    give ValidationResult {
        valid: true,
        reason: "diagnostics ok"
    }
}

proc repair() {
    emit "diagnostics repair"
}

proc diagnostics() {
    emit "diagnostics diagnostics"
}
