space arch/aarch64/boot/dtb/validator/pci

form ValidationResult {
    valid: bool
    reason: string
}

proc validate() -> ValidationResult {
    give ValidationResult {
        valid: true,
        reason: "pci ok"
    }
}

proc repair() {
    emit "pci repair"
}

proc diagnostics() {
    emit "pci diagnostics"
}
