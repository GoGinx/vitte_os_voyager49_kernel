space arch/aarch64/boot/dtb/validator/size_cells

form ValidationResult {
    valid: bool
    reason: string
}

proc validate() -> ValidationResult {
    give ValidationResult {
        valid: true,
        reason: "size_cells ok"
    }
}

proc repair() {
    emit "size_cells repair"
}

proc diagnostics() {
    emit "size_cells diagnostics"
}
