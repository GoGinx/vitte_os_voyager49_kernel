space arch/aarch64/boot/dtb/validator/interrupts

form ValidationResult {
    valid: bool
    reason: string
}

proc validate() -> ValidationResult {
    give ValidationResult {
        valid: true,
        reason: "interrupts ok"
    }
}

proc repair() {
    emit "interrupts repair"
}

proc diagnostics() {
    emit "interrupts diagnostics"
}
