space arch/aarch64/boot/dtb/compiler/linux_dts_import

form CompilerState {
    phase: string
    valid: bool
}

proc initialize() -> CompilerState {
    give CompilerState {
        phase: "linux_dts_import",
        valid: true
    }
}

proc compile() {
    emit "linux_dts_import compile"
}

proc optimize() {
    emit "linux_dts_import optimize"
}

proc debug() {
    emit "linux_dts_import debug"
}
