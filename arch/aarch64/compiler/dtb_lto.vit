space arch/aarch64/boot/dtb/compiler/dtb_lto

form CompilerState {
    phase: string
    valid: bool
}

proc initialize() -> CompilerState {
    give CompilerState {
        phase: "dtb_lto",
        valid: true
    }
}

proc compile() {
    emit "dtb_lto compile"
}

proc optimize() {
    emit "dtb_lto optimize"
}

proc debug() {
    emit "dtb_lto debug"
}
