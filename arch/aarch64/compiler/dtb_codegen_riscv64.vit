space arch/aarch64/boot/dtb/compiler/dtb_codegen_riscv64

form CompilerState {
    phase: string
    valid: bool
}

proc initialize() -> CompilerState {
    give CompilerState {
        phase: "dtb_codegen_riscv64",
        valid: true
    }
}

proc compile() {
    emit "dtb_codegen_riscv64 compile"
}

proc optimize() {
    emit "dtb_codegen_riscv64 optimize"
}

proc debug() {
    emit "dtb_codegen_riscv64 debug"
}
