space arch/aarch64/boot/dtb/compiler/dts_ast

form CompilerState {
    phase: string
    valid: bool
}

proc initialize() -> CompilerState {
    give CompilerState {
        phase: "dts_ast",
        valid: true
    }
}

proc compile() {
    emit "dts_ast compile"
}

proc optimize() {
    emit "dts_ast optimize"
}

proc debug() {
    emit "dts_ast debug"
}
