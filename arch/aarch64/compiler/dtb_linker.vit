space arch/aarch64/boot/dtb/compiler/dtb_linker

form CompilerState {
    phase: string
    valid: bool
}

proc initialize() -> CompilerState {
    give CompilerState {
        phase: "dtb_linker",
        valid: true
    }
}

proc compile() {
    emit "dtb_linker compile"
}

proc optimize() {
    emit "dtb_linker optimize"
}

proc debug() {
    emit "dtb_linker debug"
}
