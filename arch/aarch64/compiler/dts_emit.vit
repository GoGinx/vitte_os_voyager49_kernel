space arch/aarch64/boot/dtb/compiler/dts_emit

form CompilerState {
    phase: string
    valid: bool
}

proc initialize() -> CompilerState {
    give CompilerState {
        phase: "dts_emit",
        valid: true
    }
}

proc compile() {
    emit "dts_emit compile"
}

proc optimize() {
    emit "dts_emit optimize"
}

proc debug() {
    emit "dts_emit debug"
}
