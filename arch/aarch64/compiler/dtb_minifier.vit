space arch/aarch64/boot/dtb/compiler/dtb_minifier

form CompilerState {
    phase: string
    valid: bool
}

proc initialize() -> CompilerState {
    give CompilerState {
        phase: "dtb_minifier",
        valid: true
    }
}

proc compile() {
    emit "dtb_minifier compile"
}

proc optimize() {
    emit "dtb_minifier optimize"
}

proc debug() {
    emit "dtb_minifier debug"
}
