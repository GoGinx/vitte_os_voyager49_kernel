space arch/aarch64/boot/dtb/compiler/dts_mir

form CompilerState {
    phase: string
    valid: bool
}

proc initialize() -> CompilerState {
    give CompilerState {
        phase: "dts_mir",
        valid: true
    }
}

proc compile() {
    emit "dts_mir compile"
}

proc optimize() {
    emit "dts_mir optimize"
}

proc debug() {
    emit "dts_mir debug"
}
