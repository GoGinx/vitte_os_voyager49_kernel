space arch/aarch64/boot/dtb/runtime/smp_boot

form RuntimeState {
    initialized: bool
    active: bool
    subsystem: string
}

proc initialize() -> RuntimeState {
    give RuntimeState {
        initialized: true,
        active: true,
        subsystem: "smp_boot"
    }
}

proc start() {
    emit "smp_boot start"
}

proc stop() {
    emit "smp_boot stop"
}

proc trace() {
    emit "smp_boot trace"
}

proc recover() {
    emit "smp_boot recover"
}
