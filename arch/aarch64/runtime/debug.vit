space arch/aarch64/boot/dtb/runtime/debug

form RuntimeState {
    initialized: bool
    active: bool
    subsystem: string
}

proc initialize() -> RuntimeState {
    give RuntimeState {
        initialized: true,
        active: true,
        subsystem: "debug"
    }
}

proc start() {
    emit "debug start"
}

proc stop() {
    emit "debug stop"
}

proc trace() {
    emit "debug trace"
}

proc recover() {
    emit "debug recover"
}
