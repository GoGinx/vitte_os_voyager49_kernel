space arch/aarch64/boot/dtb/runtime/watchdog

form RuntimeState {
    initialized: bool
    active: bool
    subsystem: string
}

proc initialize() -> RuntimeState {
    give RuntimeState {
        initialized: true,
        active: true,
        subsystem: "watchdog"
    }
}

proc start() {
    emit "watchdog start"
}

proc stop() {
    emit "watchdog stop"
}

proc trace() {
    emit "watchdog trace"
}

proc recover() {
    emit "watchdog recover"
}
