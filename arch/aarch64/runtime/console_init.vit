space arch/aarch64/boot/dtb/runtime/console_init

form RuntimeState {
    initialized: bool
    active: bool
    subsystem: string
}

proc initialize() -> RuntimeState {
    give RuntimeState {
        initialized: true,
        active: true,
        subsystem: "console_init"
    }
}

proc start() {
    emit "console_init start"
}

proc stop() {
    emit "console_init stop"
}

proc trace() {
    emit "console_init trace"
}

proc recover() {
    emit "console_init recover"
}
