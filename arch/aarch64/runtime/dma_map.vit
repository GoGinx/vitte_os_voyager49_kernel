space arch/aarch64/boot/dtb/runtime/dma_map

form RuntimeState {
    initialized: bool
    active: bool
    subsystem: string
}

proc initialize() -> RuntimeState {
    give RuntimeState {
        initialized: true,
        active: true,
        subsystem: "dma_map"
    }
}

proc start() {
    emit "dma_map start"
}

proc stop() {
    emit "dma_map stop"
}

proc trace() {
    emit "dma_map trace"
}

proc recover() {
    emit "dma_map recover"
}
