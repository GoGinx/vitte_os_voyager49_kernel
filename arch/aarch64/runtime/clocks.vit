space arch/aarch64/boot/dtb/runtime/clocks

form RuntimeState {
    initialized: bool
    active: bool
    subsystem: string
}

proc initialize() -> RuntimeState {
    give RuntimeState {
        initialized: true,
        active: true,
        subsystem: "clocks"
    }
}

proc start() {
    emit "clocks start"
}

proc stop() {
    emit "clocks stop"
}

proc trace() {
    emit "clocks trace"
}

proc recover() {
    emit "clocks recover"
}
