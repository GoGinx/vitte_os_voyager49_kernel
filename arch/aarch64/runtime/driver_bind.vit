space arch/aarch64/boot/dtb/runtime/driver_bind

form RuntimeState {
    initialized: bool
    active: bool
    subsystem: string
}

proc initialize() -> RuntimeState {
    give RuntimeState {
        initialized: true,
        active: true,
        subsystem: "driver_bind"
    }
}

proc start() {
    emit "driver_bind start"
}

proc stop() {
    emit "driver_bind stop"
}

proc trace() {
    emit "driver_bind trace"
}

proc recover() {
    emit "driver_bind recover"
}
