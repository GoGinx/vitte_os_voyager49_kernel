space arch/aarch64/boot/dtb/runtime/telemetry

form RuntimeState {
    initialized: bool
    active: bool
    subsystem: string
}

proc initialize() -> RuntimeState {
    give RuntimeState {
        initialized: true,
        active: true,
        subsystem: "telemetry"
    }
}

proc start() {
    emit "telemetry start"
}

proc stop() {
    emit "telemetry stop"
}

proc trace() {
    emit "telemetry trace"
}

proc recover() {
    emit "telemetry recover"
}
