space arch/aarch64/boot/dtb/runtime/boot_scan

form RuntimeState {
    initialized: bool
    active: bool
    subsystem: string
}

proc initialize() -> RuntimeState {
    give RuntimeState {
        initialized: true,
        active: true,
        subsystem: "boot_scan"
    }
}

proc start() {
    emit "boot_scan start"
}

proc stop() {
    emit "boot_scan stop"
}

proc trace() {
    emit "boot_scan trace"
}

proc recover() {
    emit "boot_scan recover"
}
