space arch/aarch64/boot/dtb/runtime/thermal_probe

form RuntimeState {
    initialized: bool
    active: bool
    subsystem: string
}

proc initialize() -> RuntimeState {
    give RuntimeState {
        initialized: true,
        active: true,
        subsystem: "thermal_probe"
    }
}

proc start() {
    emit "thermal_probe start"
}

proc stop() {
    emit "thermal_probe stop"
}

proc trace() {
    emit "thermal_probe trace"
}

proc recover() {
    emit "thermal_probe recover"
}
