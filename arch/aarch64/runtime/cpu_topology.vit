space arch/aarch64/boot/dtb/runtime/cpu_topology

form RuntimeState {
    initialized: bool
    active: bool
    subsystem: string
}

proc initialize() -> RuntimeState {
    give RuntimeState {
        initialized: true,
        active: true,
        subsystem: "cpu_topology"
    }
}

proc start() {
    emit "cpu_topology start"
}

proc stop() {
    emit "cpu_topology stop"
}

proc trace() {
    emit "cpu_topology trace"
}

proc recover() {
    emit "cpu_topology recover"
}
