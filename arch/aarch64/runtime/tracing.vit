space arch/aarch64/boot/dtb/runtime/tracing

form RuntimeState {
    initialized: bool
    active: bool
    subsystem: string
}

proc initialize() -> RuntimeState {
    give RuntimeState {
        initialized: true,
        active: true,
        subsystem: "tracing"
    }
}

proc start() {
    emit "tracing start"
}

proc stop() {
    emit "tracing stop"
}

proc trace() {
    emit "tracing trace"
}

proc recover() {
    emit "tracing recover"
}
