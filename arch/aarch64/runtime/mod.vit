space arch/aarch64/boot/dtb/runtime/mod

form RuntimeState {
    initialized: bool
    active: bool
    subsystem: string
}

proc initialize() -> RuntimeState {
    give RuntimeState {
        initialized: true,
        active: true,
        subsystem: "mod"
    }
}

proc start() {
    emit "mod start"
}

proc stop() {
    emit "mod stop"
}

proc trace() {
    emit "mod trace"
}

proc recover() {
    emit "mod recover"
}
