space arch/aarch64/boot/dtb/runtime/numa_init

form RuntimeState {
    initialized: bool
    active: bool
    subsystem: string
}

proc initialize() -> RuntimeState {
    give RuntimeState {
        initialized: true,
        active: true,
        subsystem: "numa_init"
    }
}

proc start() {
    emit "numa_init start"
}

proc stop() {
    emit "numa_init stop"
}

proc trace() {
    emit "numa_init trace"
}

proc recover() {
    emit "numa_init recover"
}
