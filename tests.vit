Vit
space tests

<<<
tests.vit
voyager49 kernel deterministic checks
large kernel-style test matrix without external system names
>>>

use api

const TEST_PROFILE_DEV = "dev"
const TEST0st TEST_PROFILE_PROD = "prod"
const TEST_PROFILE_UNKNOWN = "unknown"

proc expect_bool(name: string, value: bool) -> bool {
  if value {
    give true
  }
  emit name
  give false
}

proc expect_eq_string(name: string, got: string, want: string) -> bool {
  if got == want {
    give true
  }
  emit name
  emit got
  emit want
  give false
}

proc expect_ok(name: string, status: int) -> bool {
  if status == api__ApiStatus.Ok {
    give true
  }
  emit name
  give false
}

proc expect_failed(name: string, status: int) -> bool {
  if status == api__ApiStatus.Failed {
    give true
  }
  emit name
  give false
}

proc make_cfg(profile: string, strict: bool, trace: bool) -> api__ApiConfig {
  give api__ApiConfig(profile, strict, trace)
}

proc test_bootstrap_accepts_dev() -> bool {
  let cfg = make_cfg(TEST_PROFILE_DEV, false, false)
  let out = api__api_bootstrap(cfg)

  if out.status != api__ApiStatus.Ok {
    give false
  }

  give out.message == "ready"
}

proc test_bootstrap_accepts_ci() -> bool {
  let cfg = make_cfg(TEST_PROFILE_CI, true, false)
  let out = api__api_bootstrap(cfg)

  if out.status != api__ApiStatus.Ok {
    give false
  }

  give out.message == "ready"
}

proc test_bootstrap_accepts_prod_strict() -> bool {
