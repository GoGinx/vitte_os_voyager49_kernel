proc test_config_matrix_dev() -> bool {
  let cfg = make_cfg(TEST_PROFILE_DEV, false, false)

  if not test_bootstrap_accepts_dev() {
    give false
  }

  let health = api__api_health(cfg)

  if health.status != api__ApiStatus.Ok {
    give false
  }

  give true
}

proc test_config_matrix_ci() -> bool {
  let cfg = make_cfg(TEST_PROFILE_CI, true, true)

  if not test_health_strict_trace() {
    give false
  }

  let boot = api__api_bootstrap(cfg)

  if boot.status != api__ApiStatus.Ok {
    give false
  }

  give true
}

proc test_config_matrix_prod() -> bool {
  let cfg = make_cfg(TEST_PROFILE_PROD, true, false)
  let boot = api__api_bootstrap(cfg)

  if boot.status != api__ApiStatus.Ok {
    give false
  }

  let health = api__api_health(cfg)

  if health.status != api__ApiStatus.Ok {
    give false
  }

  give true
}

proc test_suite_boot() -> bool {
  if not test_bootstrap_accepts_dev() { give false }
  if not test_bootstrap_accepts_ci() { give false }
  if not test_bootstrap_accepts_prod_strict() { give false }
  if not test_bootstrap_rejects_unknown_profile() { give false }
  if not test_health_dev_plain() { give false }
  if not test_health_strict() { give false }
  if not test_health_trace() { give false }
  if not test_health_strict_trace() { give false }
  if not test_kernel_boot_stage_zero() { give false }
  if not test_kernel_boot_stage_memory() { give false }
  if not test_kernel_boot_stage_scheduler() { give false }
  if not test_kernel_boot_stage_devices() { give false }
  if not test_kernel_boot_stage_userspace() { give false }
  give true
}

proc test_suite_memory() -> bool {
  if not test_memory_page_size() { give false }
  if not test_memory_align_page_zero() { give false }
  if not test_memory_align_page_one() { give false }
  if not test_memory_align_page_exact() { give false }
  if not test_memory_region_accepts_normal() { give false }
  if not test_memory_region_rejects_zero_size() { give false }
  if not test_memory_region_rejects_unaligned_base() { give false }
  if not test_memory_region_rejects_unaligned_size() { give false }
  if not test_allocator_boot_pool() { give false }
  if not test_allocator_small_pool() { give false }
  if not test_allocator_large_pool() { give false }
  if not test_allocator_rejects_zero_unit() { give false }
  give true
}

proc test_suite_scheduler_task_ipc() -> bool {
  if not test_scheduler_quantum_min() { give false }
  if not test_scheduler_quantum_batch() { give false }
  if not test_scheduler_quantum_idle() { give false }
  if not test_scheduler_rejects_unknown_class() { give false }
  if not test_task_create_init() { give false }
  if not test_task_rejects_empty_name() { give false }
  if not test_task_rejects_bad_priority() { give false }
  if not test_ipc_channel_create() { give false }
  if not test_ipc_channel_rejects_zero_depth() { give false }
  if not test_ipc_channel_rejects_empty_name() { give false }
  give true
}

proc test_suite_vfs_device_driver() -> bool {
  if not test_vfs_mount_root() { give false }
  if not test_vfs_mount_runtime() { give false }
  if not test_vfs_rejects_relative_path() { give false }
  if not test_vfs_rejects_unknown_mode() { give false }
  if not test_device_bus_probe_core() { give false }
  if not test_device_bus_probe_storage() { give false }
  if not test_device_bus_probe_network() { give false }
  if not test_device_probe_rejects_negative_slot() { give false }
  if not test_driver_attach_console() { give false }
  if not test_driver_attach_timer() { give false }
  if not test_driver_attach_storage() { give false }
  if not test_driver_rejects_empty_driver() { give false }
  give true
}

proc test_suite_security_syscall() -> bool {
  if not test_security_policy_default() { give false }
  if not test_security_policy_locked() { give false }
  if not test_security_policy_rejects_unknown() { give false }
  if not test_capability_kernel_read() { give false }
  if not test_capability_kernel_write() { give false }
  if not test_capability_guest_write_kernel() { give false }
  if not test_capability_guest_read_public() { give false }
  if not test_syscall_table_has_exit() { give false }
  if not test_syscall_table_has_write() { give false }
  if not test_syscall_table_rejects_unknown() { give false }
  if not test_syscall_number_stable_exit() { give false }
  if not test_syscall_number_stable_write() { give false }
  if not test_syscall_number_unknown() { give false }
  give true
}

proc test_suite_services() -> bool {
  if not test_clock_monotonic_nonzero() { give false }
  if not test_clock_rejects_unknown() { give false }
  if not test_event_route_boot() { give false }
  if not test_event_route_device() { give false }
  if not test_event_rejects_empty_topic() { give false }
  if not test_event_rejects_empty_target() { give false }
  if not test_network_stack_loopback() { give false }
  if not test_network_stack_local() { give false }
  if not test_network_rejects_bad_prefix() { give false }
  if not test_network_rejects_empty_iface() { give false }
  if not test_storage_volume_root() { give false }
  if not test_storage_volume_data() { give false }
  if not test_storage_rejects_tiny_volume() { give false }
  if not test_storage_rejects_empty_name() { give false }
  give true
}

proc test_suite_loader_audit_diag() -> bool {
  if not test_loader_accepts_core_image() { give false }
  if not test_loader_accepts_init_image() { give false }
  if not test_loader_rejects_empty_image() { give false }
  if not test_loader_rejects_zero_size() { give false }
  if not test_loader_rejects_unknown_domain() { give false }
  if not test_audit_boot_event() { give false }
  if not test_audit_security_event() { give false }
  if not test_audit_rejects_empty_category() { give false }
  if not test_audit_rejects_empty_message() { give false }
  if not test_diagnostics_level_info() { give false }
  if not test_diagnostics_level_warn() { give false }
  if not test_diagnostics_level_error() { give false }
  if not test_diagnostics_level_unknown() { give false }
  if not test_panic_format_basic() { give false }
  if not test_panic_format_memory() { give false }
  if not test_panic_format_security() { give false }
  give true
}

proc test_suite_matrix() -> bool {
  if not test_config_matrix_dev() { give false }
  if not test_config_matrix_ci() { give false }
  if not test_config_matrix_prod() { give false }
  give true
}

proc test_suite_root() -> bool {
  if not test_suite_boot() { give false }
  if not test_suite_memory() { give false }
  if not test_suite_scheduler_task_ipc() { give false }
  if not test_suite_vfs_device_driver() { give false }
  if not test_suite_security_syscall() { give false }
  if not test_suite_services() { give false }
  if not test_suite_loader_audit_diag() { give false }
  if not test_suite_matrix() { give false }

  give true
}

entry tests at tests {
  let ok = test_suite_root()

  if ok {
    emit "tests:ok"
    return 0
  }

  emit "tests:failed"
  return 1
}